# HoneyTrap AI — example environment file
#
# Copy to `.env` and fill in only the endpoints you actually use.
# Any variable left blank causes the matching alert channel to be
# skipped at startup with a warning (never a crash).
#
# Channel env vars are referenced from honeytrap.yaml / profile YAML
# files via `*_env` keys (e.g. `webhook_url_env: HONEYTRAP_SLACK_WEBHOOK_URL`).

# --- Alert channel secrets --------------------------------------------------

# Slack incoming webhook URL
HONEYTRAP_SLACK_WEBHOOK_URL=

# Discord incoming webhook URL
HONEYTRAP_DISCORD_WEBHOOK_URL=

# Microsoft Teams incoming webhook URL
HONEYTRAP_TEAMS_WEBHOOK_URL=

# Generic HTTPS webhook (custom SIEM / SOAR)
HONEYTRAP_WEBHOOK_URL=

# Shared secret used to sign the generic webhook body with HMAC-SHA256.
# Receivers should verify the `X-HoneyTrap-Signature: sha256=<hex>` header.
HONEYTRAP_WEBHOOK_SECRET=

# SMTP credentials for the email channel
HONEYTRAP_SMTP_USER=
HONEYTRAP_SMTP_PASS=
